# ── Telegram ──────────────────────────────────────────────
# [SECRETO] Nunca compartas TELEGRAM_BOT_TOKEN ni lo subas a repositorios.
TELEGRAM_BOT_TOKEN=
TELEGRAM_MODE=webhook

# [SECRETO] URL secret path: no imprimir ni subir a repositorios.
# Este valor protege el endpoint del webhook contra peticiones no deseadas.
WEBHOOK_SECRET=

PUBLIC_WEBHOOK_URL=
PORT=3000

# ── Dominio ───────────────────────────────────────────────
# Opciones: todo, adhd-coach
# Para duplicar la instancia para adhd-coach:
# 1. Crea un nuevo bot en BotFather y obtén su TELEGRAM_BOT_TOKEN.
# 2. Despliega un nuevo servicio en Railway.
# 3. Usa el nuevo TELEGRAM_BOT_TOKEN y establece DOMAIN=adhd-coach.
# 4. Asegúrate de configurar la PUBLIC_WEBHOOK_URL correspondiente al nuevo dominio en Railway.
DOMAIN=todo

# ── LLM Fallback ─────────────────────────────────────────
LLM_ENABLED=false
LLM_PROVIDER=openai
# [SECRETO] OPENAI_API_KEY no debe subirse.
OPENAI_API_KEY=

# ── Storage ───────────────────────────────────────────────
STORAGE_PROVIDER=postgres
DATABASE_URL=

# ── General ───────────────────────────────────────────────
LOG_LEVEL=info
